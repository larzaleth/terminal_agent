{
  "name": "ai-coding-agent",
  "version": "2.4.0",
  "description": "A terminal-based AI coding agent powered by Google Gemini, featuring RAG, streaming, smart planning, and cost tracking.",
  "type": "module",
  "bin": {
    "myagent": "./bin/cli.js"
  },
  "main": "./bin/cli.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node ./bin/cli.js",
    "test": "node --test --test-concurrency=1 tests/",
    "lint": "eslint ./src ./bin",
    "lint:fix": "eslint ./src ./bin --fix",
    "format": "prettier --write ./src ./bin",
    "format:check": "prettier --check ./src ./bin"
  },
  "keywords": [
    "ai",
    "agent",
    "cli",
    "gemini",
    "coding-assistant",
    "rag",
    "terminal"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@google/genai": "^1.47.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.4.1",
    "diff": "^9.0.0",
    "dotenv": "^17.3.1",
    "htm": "^3.1.1",
    "ink": "^5.2.1",
    "ink-spinner": "^5",
    "ink-text-input": "^6",
    "openai": "^6.34.0",
    "ora": "^8.2.0",
    "p-limit": "^7.1.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "globals": "^15.0.0",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.0.0"
  }
}
