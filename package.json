{
  "name": "ai-coding-agent",
  "version": "2.2.0",
  "description": "A terminal-based AI coding agent powered by Google Gemini, featuring RAG, streaming, smart planning, and cost tracking.",
  "type": "module",
  "bin": {
    "myagent": "./bin/cli.js"
  },
  "main": "./bin/cli.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node ./bin/cli.js",
    "test": "node --test tests/",
    "lint": "eslint ./src ./bin",
    "lint:fix": "eslint ./src ./bin --fix",
    "format": "prettier --write ./src ./bin",
    "format:check": "prettier --check ./src ./bin"
  },
  "keywords": [
    "ai",
    "agent",
    "cli",
    "gemini",
    "coding-assistant",
    "rag",
    "terminal"
  ],
  "license": "MIT",
  "dependencies": {
    "@google/genai": "^1.47.0",
    "chalk": "^5.4.1",
    "dotenv": "^17.3.1",
    "ora": "^8.2.0",
    "p-limit": "^7.1.1"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0"
  }
}
